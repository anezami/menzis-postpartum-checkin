# =============================================================================
# Menzis Postpartum Check-in — environment template
# For the DEFAULT Foundry provider you need NO .env at all — just run:
#   az login
# then: npm run dev
#
# Copy this file to `.env` only when you need overrides. NEVER commit `.env`.
# `.env` is already git-ignored — see .gitignore.
# =============================================================================
#
# The conversational guide "Lizz" uses Azure AI Foundry (Entra ID) by default.
# No API key required — authentication via DefaultAzureCredential (az login).
#
# Quick start (zero config):
#   az login
#   npm run dev
#   # Open: http://localhost:5173/lizz?token=demo123&moment=inschrijving
#
# See HANDOFF.md for full architecture details.
# -----------------------------------------------------------------------------

# --- Frontend flag (safe to expose; VITE_ vars ARE bundled into the client) ---
# Uncomment to DISABLE LLM and force the offline static chip flow:
# VITE_LIZZ_LLM_ENABLED=false

# --- Provider selection (server-side only; NO VITE_ prefix → never reaches browser) ---
# Default is 'foundry'. Change to 'github' to use GitHub Models instead.
# LLM_PROVIDER=foundry

# --- Azure AI Foundry overrides (only needed if using a different Foundry endpoint) ---
# FOUNDRY_ENDPOINT=https://foundrytestjes.services.ai.azure.com/openai/v1
# FOUNDRY_DEPLOYMENT=gpt-5.4-mini

# --- GitHub Models (only needed when LLM_PROVIDER=github) ---
# GITHUB_TOKEN=<your-github-token-or-run-gh-auth-token>
# GITHUB_MODELS_MODEL=openai/gpt-4.1-mini

# --- Voice: Talking Avatar + Speech-to-Text (optional overrides) ---
# Both default to the verified foundrytestjes/swedencentral resource.
# Zero-config with az login — no keys required (disableLocalAuth: true, Entra only).
# SPEECH_REGION=swedencentral
# SPEECH_RESOURCE_ID=/subscriptions/fb5cf409-7bc6-4446-aea6-d49b899eaa8b/resourceGroups/foundrytests/providers/Microsoft.CognitiveServices/accounts/foundrytestjes
