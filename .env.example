# =============================================================================
# Menzis Postpartum Check-in — environment template
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================
#
# The conversational guide "Lizz" can run in two modes:
#   1. STATIC (default, no key needed)  — scripted chip flow, fully offline.
#   2. LLM    (to be wired by colleague) — natural multilingual conversation
#      powered by an Azure AI Foundry deployment, via a SERVER-SIDE proxy so
#      the API key is never shipped to the browser.
#
# See HANDOFF.md for the full integration plan.
# -----------------------------------------------------------------------------

# --- Frontend flag (safe to expose; VITE_ vars ARE bundled into the client) ---
# Set to "true" to make the UI call the proxy at /api/lizz instead of the
# static script. Leave "false" (or unset) to keep the offline fallback.
VITE_LIZZ_LLM_ENABLED=false

# --- Proxy / server-side ONLY (NO VITE_ prefix → never reaches the browser) ---
# These are read by the local proxy (Vite dev middleware or small Node server).
FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com
FOUNDRY_DEPLOYMENT=<your-deployment-name>
FOUNDRY_API_VERSION=2024-08-01-preview
FOUNDRY_API_KEY=<paste-key-here-do-not-commit>
